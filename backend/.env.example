# ===================================================
# 🌿 Cafe' In The Garden - Environment Variables
# ===================================================
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับระบบของคุณ
# ห้าม commit ไฟล์ .env ขึ้น Git!

# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=cafe_garden

# JWT Secret Keys
# ⚠️ ควรใช้ค่า random ยาวๆ ในระบบ Production เช่น: openssl rand -base64 64
JWT_SECRET=cafe_garden_super_secret_key_change_in_production
JWT_EXPIRES_IN=8h

# CORS
FRONTEND_URL=http://localhost:5500
